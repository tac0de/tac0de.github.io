---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { copy, isLanguage, languages } from "../../i18n";
import "../../styles/global.css";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = isLanguage(Astro.params.lang) ? Astro.params.lang : "ko";
const t = copy[lang];
---

<BaseLayout title={t.aboutTitle} description={t.description} lang={lang} navEpisodes={t.navEpisodes} navAbout={t.navAbout}>
  <section class="mx-auto max-w-3xl px-5 py-14 md:py-20">
    <p data-reveal class="text-sm font-semibold uppercase tracking-[0.2em] text-brass">{t.aboutEyebrow}</p>
    <h1 data-reveal class="mt-3 font-serif text-5xl font-semibold text-bone">{t.aboutHeading}</h1>
    <div data-reveal class="reading-flow mt-8 space-y-6 text-lg leading-8 text-bone/72">
      {t.aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>
</BaseLayout>
