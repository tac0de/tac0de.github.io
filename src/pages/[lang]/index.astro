---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { collectionsByLanguage, copy, isLanguage, languages } from "../../i18n";
import "../../styles/global.css";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = isLanguage(Astro.params.lang) ? Astro.params.lang : "ko";
const t = copy[lang];
const collection = collectionsByLanguage[lang];
const episodes = (await getCollection(collection, ({ data }) => data.status === "published"))
  .sort((a, b) => b.data.episode - a.data.episode);
const latest = episodes[0];
const basePath = `/${lang}`;
const locale = lang === "ko" ? "ko-KR" : "en-US";
---

<BaseLayout title={t.title} description={t.description} lang={lang} navEpisodes={t.navEpisodes} navAbout={t.navAbout}>
  <section class="surface-grain relative min-h-[calc(100svh-57px)] overflow-hidden border-b border-bone/10" data-hero-stage>
    <picture>
      <source
        type="image/webp"
        srcset="/assets/krontium-hero-960.webp 960w, /assets/krontium-hero-1600.webp 1600w"
        sizes="100vw"
      />
      <img
        data-hero-visual
        class="hero-visual absolute inset-0 h-full w-full scale-[1.04] object-cover opacity-70"
        src="/assets/krontium-hero.png"
        alt="A dark metallic crown city forged from Krontium"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </picture>
    <div class="hero-slice hero-slice-a" data-hero-slice></div>
    <div class="hero-slice hero-slice-b" data-hero-slice></div>
    <div class="hero-slice hero-slice-c" data-hero-slice></div>
    <div class="hero-edge-waves" data-hero-edge-frame aria-hidden="true">
      <span class="hero-wave hero-wave-top"></span>
      <span class="hero-wave hero-wave-right"></span>
      <span class="hero-wave hero-wave-bottom"></span>
      <span class="hero-wave hero-wave-left"></span>
    </div>
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(7,9,13,0.92)_0%,rgba(7,9,13,0.62)_42%,rgba(7,9,13,0.10)_100%),linear-gradient(180deg,rgba(7,9,13,0.05)_0%,rgba(7,9,13,0.82)_100%)]"></div>
    <div class="hero-scanline absolute inset-x-0 top-[18%] h-px opacity-80"></div>
    <div class="relative z-10 mx-auto grid max-w-7xl gap-12 px-5 pb-12 pt-14 md:grid-cols-[0.94fr_1.06fr] md:pb-16 md:pt-20 lg:pt-24">
      <div data-hero-copy class="flex min-h-[68svh] flex-col justify-center">
        <p data-reveal class="mb-5 text-sm font-semibold uppercase tracking-[0.22em] text-brass">{t.eyebrow}</p>
        <h1 data-reveal class="krontium-title max-w-4xl font-serif text-6xl font-semibold leading-[0.9] text-bone md:text-8xl lg:text-9xl" data-title-glow>Krontium</h1>
        <div data-reveal class="memory-rule mt-7 h-px w-48"></div>
        <p data-reveal class="mt-7 max-w-2xl text-xl leading-9 text-bone/82 md:text-2xl md:leading-10">{t.heroLine1}</p>
        <p data-reveal class="mt-5 max-w-xl text-lg leading-8 text-cold/86">{t.heroLine2}</p>
        <div data-reveal class="mt-9 flex flex-wrap gap-3">
          <a class="hero-primary-cta rounded-md bg-bone px-5 py-3 text-sm font-semibold text-ink shadow-[0_0_34px_rgba(197,155,85,0.22)] transition hover:bg-brass" href={`${basePath}/episodes/${latest.id}/`}>
            {t.readLatest}
          </a>
          <a class="rounded-md border border-bone/24 bg-night/40 px-5 py-3 text-sm font-semibold text-bone transition hover:border-brass/70" href={`${basePath}/episodes/`}>
            {t.openLedger}
          </a>
        </div>
        <dl data-reveal class="mt-12 grid max-w-xl grid-cols-3 divide-x divide-bone/15 border-y border-bone/15 py-4 text-sm">
          <div class="pr-4">
            <dt class="text-bone/48">{t.forged}</dt>
            <dd class="mt-1 font-semibold text-bone">{t.forgedValue}</dd>
          </div>
          <div class="px-4">
            <dt class="text-bone/48">{t.published}</dt>
            <dd class="mt-1 font-semibold text-bone">{episodes.length}</dd>
          </div>
          <div class="pl-4">
            <dt class="text-bone/48">{t.cost}</dt>
            <dd class="mt-1 font-semibold text-bone">{t.costValue}</dd>
          </div>
        </dl>
        <p data-reveal class="mt-5 text-sm font-medium text-bone/46">{t.cadence}</p>
      </div>
      <aside data-reveal class="metal-panel fracture-mask self-end border border-bone/15 p-6 shadow-[0_34px_110px_rgba(0,0,0,0.42)] backdrop-blur">
        <div class="flex items-center justify-between gap-5 border-b border-bone/12 pb-5">
          <p class="text-sm font-semibold text-brass">{t.latest}</p>
          <p class="text-sm text-bone/50">{t.part} {String(latest.data.episode).padStart(2, "0")}</p>
        </div>
        <h2 class="mt-6 font-serif text-3xl font-semibold leading-tight text-bone">{latest.data.title}</h2>
        <p class="mt-4 leading-7 text-bone/68">{latest.data.description}</p>
        <p class="mt-7 text-sm text-cold/60">{latest.data.publishedAt.toLocaleDateString(locale)}</p>
        <div class="mt-8 grid grid-cols-3 gap-2 text-xs uppercase tracking-[0.16em] text-bone/46">
          <span data-memory-shard class="border border-bone/10 px-3 py-2">birth</span>
          <span data-memory-shard class="border border-bone/10 px-3 py-2">name</span>
          <span data-memory-shard class="border border-ember/30 px-3 py-2 text-ember">oath</span>
        </div>
      </aside>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-14 md:py-20">
    <div data-reveal class="flex items-end justify-between gap-5">
      <div>
        <p class="text-sm font-semibold text-brass">{t.archiveEyebrow}</p>
        <h2 class="mt-2 font-serif text-4xl font-semibold text-bone">{t.archiveTitle}</h2>
      </div>
      <a class="text-sm font-semibold text-brass hover:text-bone" href={`${basePath}/episodes/`}>{t.allEpisodes}</a>
    </div>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {episodes.slice(0, 4).map((episode) => (
        <a data-episode-card data-scroll-reveal class="metal-panel rounded-md border border-bone/12 p-6 shadow-[0_16px_54px_rgba(0,0,0,0.18)] transition-colors hover:border-brass/55" href={`${basePath}/episodes/${episode.id}/`}>
          <div class="flex items-center justify-between gap-5">
            <p class="text-sm font-semibold text-cold">CHAPTER {String(episode.data.episode).padStart(2, "0")}</p>
            <p class="text-sm text-bone/45">{episode.data.publishedAt.toLocaleDateString(locale)}</p>
          </div>
          <h3 class="mt-4 font-serif text-2xl font-semibold text-bone">{episode.data.title}</h3>
          <p class="mt-3 leading-7 text-bone/64">{episode.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
