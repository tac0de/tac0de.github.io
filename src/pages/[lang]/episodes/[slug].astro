---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { collectionsByLanguage, copy, isLanguage, languages } from "../../../i18n";
import "../../../styles/global.css";

export async function getStaticPaths() {
  const paths = [];

  for (const lang of languages) {
    const episodes = await getCollection(collectionsByLanguage[lang], ({ data }) => data.status === "published");
    paths.push(
      ...episodes.map((episode) => ({
        params: { lang, slug: episode.id },
        props: { episode, lang }
      }))
    );
  }

  return paths;
}

const lang = isLanguage(Astro.props.lang) ? Astro.props.lang : "ko";
const { episode } = Astro.props;
const t = copy[lang];
const { Content } = await render(episode);
const collection = collectionsByLanguage[lang];
const episodes = (await getCollection(collection, ({ data }) => data.status === "published"))
  .sort((a, b) => a.data.episode - b.data.episode);
const currentIndex = episodes.findIndex((item) => item.id === episode.id);
const previous = currentIndex > 0 ? episodes[currentIndex - 1] : undefined;
const next = currentIndex >= 0 ? episodes[currentIndex + 1] : undefined;
---

<BaseLayout title={`${episode.data.title} | Krontium`} description={episode.data.description} lang={lang} navEpisodes={t.navEpisodes} navAbout={t.navAbout}>
  <article class="reader-surface mx-auto max-w-[46rem] px-5 py-12 md:py-20">
    <a data-reveal class="text-sm font-semibold text-brass hover:text-bone" href={`/${lang}/episodes/`}>{t.backEpisodes}</a>
    <header data-reveal class="mt-8 border-b border-bone/12 pb-8">
      <p class="text-sm font-semibold text-cold">CHAPTER {String(episode.data.episode).padStart(2, "0")}</p>
      <h1 class="mt-3 font-serif text-4xl font-semibold leading-tight text-bone md:text-6xl">{episode.data.title}</h1>
      <p class="mt-5 leading-7 text-bone/62">{episode.data.description}</p>
      <p class="mt-5 text-sm text-bone/45">{t.cadence}</p>
    </header>
    <div data-reveal class={`reading-flow reader-copy prose prose-invert mt-10 max-w-none font-serif ${lang === "ko" ? "reader-copy-ko" : "reader-copy-en"}`}>
      <Content />
    </div>
    <nav data-reveal class="chapter-cta mt-16 border-t border-bone/12 pt-8">
      {next ? (
        <a class="chapter-cta-primary group block overflow-hidden rounded-md border border-brass/35 p-6 shadow-[0_24px_90px_rgba(0,0,0,0.28)] transition hover:border-brass/80 md:p-8" href={`/${lang}/episodes/${next.id}/`}>
          <span class="chapter-gate-panel chapter-gate-left" aria-hidden="true"></span>
          <span class="chapter-gate-panel chapter-gate-right" aria-hidden="true"></span>
          <span class="chapter-gate-crack" aria-hidden="true"></span>
          <span class="relative z-10 block text-sm font-semibold uppercase tracking-[0.2em] text-brass">{t.continueReading}</span>
          <span class="relative z-10 mt-3 block font-serif text-3xl leading-tight text-bone md:text-4xl">{next.data.title}</span>
          <span class="relative z-10 mt-4 block text-sm text-bone/52">{t.continueHint}</span>
        </a>
      ) : (
        <a class="chapter-cta-primary group block overflow-hidden rounded-md border border-brass/30 p-6 shadow-[0_24px_90px_rgba(0,0,0,0.22)] transition hover:border-brass/70 md:p-8" href={`/${lang}/episodes/`}>
          <span class="chapter-gate-panel chapter-gate-left" aria-hidden="true"></span>
          <span class="chapter-gate-panel chapter-gate-right" aria-hidden="true"></span>
          <span class="chapter-gate-crack" aria-hidden="true"></span>
          <span class="relative z-10 block text-sm font-semibold uppercase tracking-[0.2em] text-brass">{t.noNextEpisode}</span>
          <span class="relative z-10 mt-3 block font-serif text-3xl leading-tight text-bone md:text-4xl">{t.returnToArchive}</span>
        </a>
      )}
      <div class="mt-4 flex flex-wrap items-center justify-between gap-3 text-sm">
        {previous ? (
          <a class="text-bone/48 transition hover:text-bone" href={`/${lang}/episodes/${previous.id}/`}>{t.previousEpisode}: {previous.data.title}</a>
        ) : (
          <span class="text-bone/32">{t.noPreviousEpisode}</span>
        )}
        <a class="font-semibold text-brass transition hover:text-bone" href={`/${lang}/episodes/`}>{t.returnToArchive}</a>
      </div>
    </nav>
  </article>
</BaseLayout>
