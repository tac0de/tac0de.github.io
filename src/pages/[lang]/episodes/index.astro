---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { collectionsByLanguage, copy, isLanguage, languages } from "../../../i18n";
import "../../../styles/global.css";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = isLanguage(Astro.params.lang) ? Astro.params.lang : "ko";
const t = copy[lang];
const collection = collectionsByLanguage[lang];
const episodes = (await getCollection(collection, ({ data }) => data.status === "published"))
  .sort((a, b) => a.data.episode - b.data.episode);
const basePath = `/${lang}`;
const locale = lang === "ko" ? "ko-KR" : "en-US";
const archiveSeed = [
  ...episodes.map((episode) => episode.data.description),
  ...t.archiveRecords,
  ...episodes.map((episode) => episode.data.title)
];
const archiveRecords = [...archiveSeed, ...archiveSeed];
---

<BaseLayout title={t.episodesTitle} description={t.description} lang={lang} navEpisodes={t.navEpisodes} navAbout={t.navAbout}>
  <section class="archive-page relative overflow-hidden px-5 py-14 md:py-20">
    <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.78fr_1.22fr]">
      <header class="lg:sticky lg:top-28 lg:self-start">
        <p data-reveal class="text-sm font-semibold uppercase tracking-[0.2em] text-brass">{t.archiveEyebrow}</p>
        <h1 data-reveal class="mt-3 font-serif text-5xl font-semibold leading-tight text-bone md:text-6xl">{t.archiveTitle}</h1>
        <p data-reveal class="mt-5 max-w-2xl leading-8 text-bone/62">{t.episodesIntro}</p>
        <p data-reveal class="mt-4 text-sm font-medium text-brass/85">{t.cadence}</p>
      </header>

      <div>
        <div data-reveal class="divide-y divide-bone/10 border-y border-bone/14">
          {episodes.map((episode) => (
            <a data-episode-card data-scroll-reveal class="episode-fragment grid gap-3 px-1 py-7 md:grid-cols-[8rem_1fr_auto] md:gap-8" href={`${basePath}/episodes/${episode.id}/`}>
              <p class="text-sm font-semibold text-cold">CHAPTER {String(episode.data.episode).padStart(2, "0")}</p>
              <div>
                <h2 class="font-serif text-2xl font-semibold text-bone">{episode.data.title}</h2>
                <p class="mt-2 leading-7 text-bone/62">{episode.data.description}</p>
              </div>
              <p class="text-sm text-bone/45 md:pt-2">{episode.data.publishedAt.toLocaleDateString(locale)}</p>
            </a>
          ))}
        </div>

        <div class="archive-loop-window mt-16" data-archive-rail>
          <div class="archive-loop-track">
            {archiveRecords.map((record, index) => (
              <div class="archive-record" data-archive-record>
                <span>{t.archiveLoopLabel} {String((index % archiveSeed.length) + 1).padStart(2, "0")}</span>
                <p>{record}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
