---
import "../styles/global.css";
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Krontium</title>
    <script is:inline>
      const preferred = navigator.languages?.[0] || navigator.language || "ko";
      const target = preferred.toLowerCase().startsWith("ko") ? "/ko/" : "/en/";
      location.replace(target);
    </script>
  </head>
  <body class="grid min-h-screen place-items-center bg-night px-5 text-bone">
    <main class="max-w-xl text-center">
      <h1 class="font-serif text-6xl font-semibold">Krontium</h1>
      <p class="mt-5 text-bone/70">Choose language / 언어 선택</p>
      <div class="mt-8 flex justify-center gap-3">
        <a class="rounded-md border border-bone/20 px-5 py-3 text-sm font-semibold" href="/ko/">한국어</a>
        <a class="rounded-md border border-bone/20 px-5 py-3 text-sm font-semibold" href="/en/">English</a>
      </div>
    </main>
  </body>
</html>
